# Copier ce fichier en .env et remplir les valeurs avant de lancer Docker

# ── Base de données ──────────────────────────────────────────────────────────
# Mot de passe PostgreSQL (choisir quelque chose de solide)
DB_PASSWORD=change_me_strong_password_here

# ── JWT ──────────────────────────────────────────────────────────────────────
# Clé secrète JWT — minimum 32 caractères, totalement aléatoire
# Générer avec : openssl rand -base64 48
JWT_KEY=change_me_to_a_very_long_random_secret_key_32chars_minimum

# ── URL de l'application ─────────────────────────────────────────────────────
# L'URL publique de ton VPS (utilisée pour le CORS)
# Exemples :
#   http://51.210.xxx.xxx       <- IP OVH directe
#   https://monapp.example.com  <- domaine avec HTTPS
APP_URL=http://TON_IP_VPS

# ── Port exposé ──────────────────────────────────────────────────────────────
# 80 si tu veux accéder directement, autre port si tu as déjà un Nginx sur le VPS
APP_PORT=80
